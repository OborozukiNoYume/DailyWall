# Bing wallpaper markets to crawl (comma-separated)
MARKETS=["zh-CN","en-US","en-GB","en-IN","en-CA","ja-JP","de-DE","fr-FR","it-IT","es-ES","pt-BR"]

# HTTP proxy for accessing international Bing markets (empty = no proxy)
PROXY_URL=http://192.168.3.100:7890

# Thumbnail width in pixels
THUMBNAIL_WIDTH=200

# Preview max width in pixels
PREVIEW_MAX_WIDTH=1920

# API server settings
API_HOST=0.0.0.0
API_PORT=8000
